# Server
PORT=8081

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT
JWT_SECRET=change-me-to-a-long-random-string

# IMDB
IMDB_API_KEY=your-imdb-api-key

# OpenSubtitles
OPENSUBTITLES_USERAGENT=TemporaryUserAgent
OPENSUBTITLES_USERNAME=your-username
OPENSUBTITLES_PASSWORD=your-password

# Email (Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Torrent Search
TORRENT_PROVIDERS=1337x,ThePirateBay,Yts
TORRENT_SEARCH_LIMIT=20
TORRENT_CACHE_TTL_HOURS=24
