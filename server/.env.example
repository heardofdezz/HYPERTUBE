# Server
PORT=8081

# MongoDB (local by default, override for cloud)
MONGODB_URI=mongodb://localhost:27017/hypertube

# OMDB metadata (free key: https://www.omdbapi.com/apikey.aspx)
IMDB_API_KEY=your-omdb-api-key

# OpenSubtitles (optional, for subtitles)
OPENSUBTITLES_USERAGENT=TemporaryUserAgent
OPENSUBTITLES_USERNAME=your-username
OPENSUBTITLES_PASSWORD=your-password

# Torrent search (optional)
# Comma-separated list of provider names supported by torrent-search-api.
# If empty, live search and the continuous indexer are disabled — you can still
# stream from magnet URIs you supply directly via the API.
TORRENT_PROVIDERS=

# Optional: comma-separated search terms for the background indexer.
# If empty, the indexer is disabled. Example: SEARCH_QUERIES=public domain,classical music
SEARCH_QUERIES=

TORRENT_SEARCH_LIMIT=20
TORRENT_CACHE_TTL_HOURS=24
