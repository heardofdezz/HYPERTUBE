# Server
PORT=8081

# MongoDB (local by default, override for cloud)
MONGODB_URI=mongodb://localhost:27017/hypertube

# IMDB
IMDB_API_KEY=your-imdb-api-key

# OpenSubtitles
OPENSUBTITLES_USERAGENT=TemporaryUserAgent
OPENSUBTITLES_USERNAME=your-username
OPENSUBTITLES_PASSWORD=your-password

# Torrent Search
TORRENT_PROVIDERS=1337x,ThePirateBay,Yts
TORRENT_SEARCH_LIMIT=20
TORRENT_CACHE_TTL_HOURS=24
